# ==============================================================================
# REAL-TIME COLLABORATIVE CODE REVIEW TOOL - ENVIRONMENT VARIABLES CONFIGURATION
# ==============================================================================

# ─── BACKEND CONFIGURATION ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# MongoDB Connection String
MONGO_URI=mongodb://localhost:27017/collab-code-review

# JWT Settings
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# CORS Allowed Origin
CLIENT_ORIGIN=http://localhost:5173

# Socket.IO Handshake Configuration
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000

# LLM API Credentials (Optional - Falls back to static code analysis if omitted)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# ─── FRONTEND CONFIGURATION ──────────────────────────────────────────────────
# Base API URL for Axios client requests
VITE_API_BASE_URL=http://localhost:5000/api

# Connection address for Socket.IO real-time sync
VITE_SOCKET_URL=http://localhost:5000
